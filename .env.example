# Local: copy to .env — dev uses this. Include /api to match Laravel routes.
VITE_API_URL=http://103.208.183.250:9000/api

# Netlify: do not set VITE_API_URL so the built app uses /api (same-origin).
# netlify.toml proxies /api/* → your backend (HTTPS page → no mixed content).
# Or set VITE_API_URL=https://your-api-domain.example/api if the API is public HTTPS.
